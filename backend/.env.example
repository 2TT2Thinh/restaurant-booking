# ========== PRODUCTION CHECKLIST ==========
# 1. NEVER commit real .env to git (add .env to .gitignore)
# 2. Use strong random values for SECRET_KEY
# 3. Use database credentials with limited permissions
# 4. Enable HTTPS and set SECURE_PROXY_HEADER
# 5. Set SENTRY_DSN for error tracking
# 6. Update ALLOWED_ORIGINS to production domain only

# ========== DATABASE ==========
# Use separate credentials with minimal permissions for non-admin ops
DATABASE_URL=postgresql+asyncpg://booking_user:YOUR_SECURE_PASSWORD@localhost:5432/restaurant_booking

# ========== AUTHENTICATION ==========
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_32_char_min_random_secret_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ========== ENVIRONMENT ==========
# Options: development, staging, production
ENVIRONMENT=development

# ========== CORS & FRONTEND ==========
FRONTEND_URL=http://localhost:5173
# For production: FRONTEND_URL=https://yourdomain.com
# ALLOWED_ORIGINS will default to FRONTEND_URL

# ========== AI SERVICES ==========
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL_NAME=llama3:latest
OLLAMA_TIMEOUT=120

# ========== INTERNAL API ==========
INTERNAL_BASE_URL=http://localhost:8000/api/v1
# For Docker: http://backend:8000/api/v1

# ========== OPTIONAL: MONITORING ==========
SENTRY_DSN=
ENABLE_METRICS=false
METRICS_PORT=9090

# ========== OPTIONAL: CACHING ==========
REDIS_URL=
ENABLE_CHATBOT_CACHE=false

# ========== OPTIONAL: GOOGLE MAPS ==========
GOOGLE_MAPS_API_KEY=
